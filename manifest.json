{
  "manifest_version": 3,
  "name": "懒羊羊大王 · 执行力助手",
  "short_name": "懒羊羊大王",
  "description": "把大任务拆成超简单的小步骤，每完成一步都有懒羊羊的鼓励～ 一步一步征服拖延症！",
  "version": "0.5.2",
  "author": "夏凯文",
  "action": {
    "default_title": "打开懒羊羊大王",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png",
    "256": "icons/icon-256.png"
  },
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "permissions": [
    "storage",
    "notifications",
    "identity",
    "tabs"
  ],
  "host_permissions": [
    "https://github.com/*",
    "https://api.github.com/*",
    "https://*/*",
    "http://*/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "popup/popup.html",
        "popup/popup.css",
        "popup/popup.js",
        "manifest.webmanifest",
        "service-worker.js",
        "icons/*",
        "lib/*",
        "options/*"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+L",
        "mac": "Alt+L"
      },
      "description": "唤出懒羊羊大王"
    }
  }
}
